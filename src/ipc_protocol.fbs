namespace core;

table OkPayload {
}

table ErrorPayload {
}

table CreateInitialCredentialPayload {
    username: string;
    password: string;
}

union Payload {
    OkPayload,
    ErrorPayload,
    CreateInitialCredentialPayload
}

table Message {
    return_path: string;
    payload: Payload;
}

root_type Message;
